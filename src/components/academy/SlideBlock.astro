---
import type { SlideBlock } from "../../data/academy/types";
import { isSpreadsheetCellHighlighted, spreadsheetToTsv } from "../../lib/spreadsheet";
import { codeHasMarks, highlightCodeMarkup, stripCodeMarks } from "../../lib/code-highlight";

type Props = {
  blocks?: SlideBlock[];
};

const { blocks = [] } = Astro.props;

const columnLetters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ".split("");

function showCodeCopy(block: Extract<SlideBlock, { type: "code" }>): boolean {
  if (block.copyable === false) return false;
  return block.copyable === true || block.language === "excel" || block.language === "python";
}

const calloutStyles = {
  tip: "border-brand/30 bg-brand/8",
  note: "border-white/15 bg-white/[0.04]",
  warning: "border-red-500/30 bg-red-500/8",
} as const;

const calloutLabels = {
  tip: "Tip",
  note: "Nota",
  warning: "Atención",
} as const;

const boxStyles = {
  default: "border-white/10 bg-white/[0.03]",
  brand: "border-brand/30 bg-brand/8",
  muted: "border-white/8 bg-surface-card",
  warning: "border-red-500/25 bg-red-500/8",
} as const;
---

{
  blocks.map((block) => {
    if (block.type === "heading") {
      const Tag = block.level === 3 ? "h3" : "h2";
      return (
        <div class="slide-block slide-block--heading">
          <Tag
            class:list={[
              "font-semibold tracking-tight text-text",
              block.level === 3 ? "mb-3 text-base sm:text-lg" : "mb-4 text-lg sm:text-xl",
            ]}
          >
            {block.text}
          </Tag>
        </div>
      );
    }

    if (block.type === "paragraph") {
      return (
        <div class="slide-block slide-block--paragraph">
          <p class="text-sm leading-relaxed text-text-muted sm:text-base">{block.text}</p>
        </div>
      );
    }

    if (block.type === "quote") {
      return (
        <div class="slide-block slide-block--quote">
          <blockquote class="border-l-2 border-brand/50 py-1 pl-4 text-sm italic leading-relaxed text-text-muted sm:text-base">
            {block.text}
          </blockquote>
        </div>
      );
    }

    if (block.type === "list") {
      const listClass =
        block.style === "check"
          ? "slide-list-check space-y-2"
          : block.style === "numbered"
            ? "slide-list-numbered space-y-2.5"
            : "list-disc space-y-2 pl-5 marker:text-brand";

      return (
        <div class="slide-block slide-block--list">
          <ul class:list={["text-sm leading-relaxed text-text-muted sm:text-base", listClass]}>
            {block.items.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      );
    }

    if (block.type === "callout") {
      return (
        <div class="slide-block slide-block--callout">
          <div class:list={["rounded-[14px] border px-4 py-3.5 sm:px-5", calloutStyles[block.variant]]}>
            <span class="mb-1 block font-mono text-[10px] font-medium uppercase tracking-widest text-brand">
              {calloutLabels[block.variant]}
            </span>
            <p class="text-sm leading-relaxed text-text sm:text-[15px]">{block.text}</p>
          </div>
        </div>
      );
    }

    if (block.type === "code") {
      const canCopy = showCodeCopy(block);
      const copyText = stripCodeMarks(block.code);
      const copyLabel = block.language === "python" ? "Copiar código" : "Copiar fórmula";

      return (
        <div class="slide-block slide-block--code">
          <div class="overflow-x-auto rounded-[14px] border border-white/10 bg-black/40">
            <div class="flex items-center justify-between gap-3 border-b border-white/8 px-4 py-2">
              <span class="font-mono text-[11px] uppercase tracking-wider text-text-dim">{block.language}</span>
              {
                canCopy && (
                  <button type="button" class="slide-copy-btn" data-copy-btn data-copy-text={copyText}>
                    {copyLabel}
                  </button>
                )
              }
            </div>
            <pre class="slide-code__pre p-4 font-mono text-sm leading-relaxed text-text sm:text-[15px]">
              {
                codeHasMarks(block.code) ? (
                  <code class="slide-code__content" set:html={highlightCodeMarkup(block.code)} />
                ) : (
                  <code class="slide-code__content">{block.code}</code>
                )
              }
            </pre>
          </div>
          {block.caption && <p class="slide-code__caption">{block.caption}</p>}
        </div>
      );
    }

    if (block.type === "columns") {
      const gridClass =
        block.cols === 3
          ? "grid gap-4 sm:grid-cols-2 lg:grid-cols-3"
          : "grid gap-4 sm:grid-cols-2";

      return (
        <div class="slide-block slide-block--columns">
          <div class={gridClass}>
            {block.columns.map((column) => (
              <div class="space-y-3">
                <Astro.self blocks={column} />
              </div>
            ))}
          </div>
        </div>
      );
    }

    if (block.type === "cards") {
      return (
        <div class="slide-block slide-block--cards">
          <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
            {block.items.map((item) => (
              <div class="rounded-[14px] border border-white/8 bg-surface-card p-4 text-center">
                {item.icon && <div class="mb-2 text-2xl" aria-hidden="true">{item.icon}</div>}
                <strong class="mb-1 block text-sm font-semibold text-text">{item.title}</strong>
                <p class="text-xs leading-relaxed text-text-muted sm:text-sm">{item.text}</p>
              </div>
            ))}
          </div>
        </div>
      );
    }

    if (block.type === "boxes") {
      return (
        <div class="slide-block slide-block--boxes">
          <div class="grid gap-3 sm:grid-cols-2">
            {block.items.map((item) => (
              <div class:list={["rounded-[14px] border p-4", boxStyles[item.variant ?? "default"]]}>
                <h3 class="mb-2 text-sm font-semibold text-text">{item.title}</h3>
                <div class="space-y-2">
                  <Astro.self blocks={item.blocks} />
                </div>
              </div>
            ))}
          </div>
        </div>
      );
    }

    if (block.type === "figure") {
      return (
        <div class="slide-block slide-block--figure">
          <figure class="slide-figure">
            <img src={block.src} alt={block.alt} class="slide-figure__img" loading="lazy" decoding="async" />
            {block.caption && <figcaption class="slide-figure__caption">{block.caption}</figcaption>}
          </figure>
        </div>
      );
    }

    if (block.type === "imagePlaceholder") {
      return (
        <div class="slide-block slide-block--imagePlaceholder">
          <div class="slide-image-placeholder" role="img" aria-label={block.label}>
            <span class="slide-image-placeholder__icon" aria-hidden="true">🖼️</span>
            <p class="slide-image-placeholder__label">{block.label}</p>
            {block.note && <p class="slide-image-placeholder__note">{block.note}</p>}
          </div>
        </div>
      );
    }

    if (block.type === "link") {
      const external = block.external !== false;
      return (
        <div class="slide-block slide-block--link">
          <a
            href={block.href}
            class="slide-external-link"
            {...(external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
          >
            {block.label}
            {external && <span class="slide-external-link__icon" aria-hidden="true">↗</span>}
          </a>
        </div>
      );
    }

    if (block.type === "spreadsheet") {
      const tsv = spreadsheetToTsv(block.headers, block.rows);

      return (
        <div class="slide-block slide-block--spreadsheet">
          <div class="slide-spreadsheet">
            <div class="slide-spreadsheet__toolbar">
              {block.title && <p class="slide-spreadsheet__title">{block.title}</p>}
              <button type="button" class="slide-copy-btn" data-copy-btn data-copy-text={tsv}>
                {block.copyLabel ?? "Copiar tabla"}
              </button>
            </div>
            <div class="slide-spreadsheet__scroll">
              <table class="slide-spreadsheet__table">
                <thead>
                  <tr>
                    <th class="slide-spreadsheet__corner" scope="col" aria-hidden="true" />
                    {block.headers.map((header, colIndex) => (
                      <th class="slide-spreadsheet__col-head" scope="col">
                        <span class="slide-spreadsheet__letter">{columnLetters[colIndex]}</span>
                        <span>{header}</span>
                      </th>
                    ))}
                  </tr>
                </thead>
                <tbody>
                  {block.rows.map((row, rowIndex) => (
                    <tr>
                      <th class="slide-spreadsheet__row-head" scope="row">
                        {rowIndex + 1}
                      </th>
                      {row.map((cell, colIndex) => (
                        <td
                          class:list={[
                            "slide-spreadsheet__cell",
                            isSpreadsheetCellHighlighted(block.highlights, rowIndex, colIndex) &&
                              "slide-spreadsheet__cell--highlight",
                          ]}
                        >
                          {cell}
                        </td>
                      ))}
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
            {block.caption && <p class="slide-spreadsheet__caption">{block.caption}</p>}
          </div>
        </div>
      );
    }

    if (block.type === "youtube") {
      const embedTitle = block.title ?? "Video de YouTube";
      const startParam = block.start ? `?start=${block.start}` : "";

      return (
        <div class="slide-block slide-block--youtube">
          <figure class:list={["slide-youtube", block.short && "slide-youtube--short"]}>
            <div class="slide-youtube__frame">
              <iframe
                src={`https://www.youtube.com/embed/${block.videoId}${startParam}`}
                title={embedTitle}
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen
                loading="lazy"
                referrerpolicy="strict-origin-when-cross-origin"
              />
            </div>
            {block.caption && <figcaption class="slide-youtube__caption">{block.caption}</figcaption>}
          </figure>
        </div>
      );
    }

    return null;
  })
}
