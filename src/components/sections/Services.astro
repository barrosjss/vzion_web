---
import Container from "../ui/Container.astro";
import Eyebrow from "../ui/Eyebrow.astro";
import Button from "../ui/Button.astro";
import ServiceCard from "../ui/ServiceCard.astro";
import BrandImage from "../ui/BrandImage.astro";
import { services } from "../../data/services";
---

<section class="py-8 md:pb-24">
  <Container>
    <div class="mb-11 flex flex-wrap items-end justify-between gap-8">
      <div class="max-w-[48ch]">
        <Eyebrow class="mb-5">[ 02 ] servicios</Eyebrow>
        <h2 class="text-[clamp(2rem,4vw,2.875rem)] leading-[1.07] font-medium tracking-[-0.03em]">
          Todo el ecosistema digital, en un solo equipo.
        </h2>
      </div>
      <Button href="/servicios" variant="mono">ver_todos →</Button>
    </div>

    <div class="grid gap-3.5 sm:grid-cols-2 lg:grid-cols-3">
      {services.map((service) => <ServiceCard service={service} href={`/servicios/${service.id}`} />)}

      <div
        class="flex min-h-[188px] flex-col justify-between rounded-2xl border border-white/10 bg-gradient-to-br from-[#1c1a17] to-surface-raised p-6"
      >
        <BrandImage variant="orange" class="h-7 w-auto" width={28} height={28} />
        <div>
          <h3 class="mt-4 mb-2 text-xl font-semibold tracking-tight">¿No encaja en una casilla?</h3>
          <p class="mb-4 text-sm leading-normal text-text-muted">Entramos en cualquier punto de tu proceso.</p>
          <Button href="/contacto" size="sm">Hablemos →</Button>
        </div>
      </div>
    </div>
  </Container>
</section>
