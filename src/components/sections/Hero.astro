---
import Container from "../ui/Container.astro";
import Button from "../ui/Button.astro";
import BrandImage from "../ui/BrandImage.astro";
import { orbitNodes } from "../../data/services";
---

<section class="relative overflow-hidden pt-24 pb-8 sm:pt-28 md:pt-[104px] md:pb-10">
  <div
    class="pointer-events-none absolute top-[-120px] left-1/2 h-[520px] w-full max-w-[900px] -translate-x-1/2 bg-[radial-gradient(closest-side,rgba(247,148,29,0.18),rgba(247,148,29,0)_75%)]"
    aria-hidden="true"
  />

  <Container size="md">
    <div class="relative z-[2] mx-auto max-w-[1000px] text-center">
      <div
        class="mb-7 inline-flex max-w-full items-center gap-2.5 rounded-full border border-white/12 bg-white/[0.03] px-3 py-1.5 sm:mb-9 sm:px-4"
      >
        <span class="h-1.5 w-1.5 shrink-0 animate-vz-pulse rounded-full bg-brand"></span>
        <span class="font-mono text-[10px] font-medium uppercase tracking-[0.12em] text-text-muted sm:text-[11.5px] sm:tracking-[0.16em]">
          Socio operativo · as-a-service
        </span>
      </div>

      <h1 class="mx-auto max-w-[15ch] text-[clamp(2rem,8vw,4.625rem)] leading-[1.05] font-medium tracking-[-0.035em]">
        Tú llevas la visión.<br />Nosotros, la <span class="text-brand">operación</span>.
      </h1>

      <p class="mx-auto mt-5 max-w-[58ch] text-base leading-relaxed text-text-muted sm:mt-7 sm:text-lg md:text-[19px]">
        El brazo operativo que ejecuta lo que tú vendes. Tecnología, talento y proceso que se acoplan a tu
        metodología — para que tu servicio funcione y escale.
      </p>

      <div class="mt-8 flex flex-col items-stretch gap-3 sm:mt-10 sm:flex-row sm:flex-wrap sm:items-center sm:justify-center">
        <Button href="/servicios" size="lg" class="w-full sm:w-auto">Explorar servicios</Button>
        <Button href="/contacto" variant="secondary" size="lg" class="w-full sm:w-auto">Hablemos →</Button>
      </div>
    </div>
  </Container>

  <!-- Mobile: pills simplificados -->
  <Container class="relative z-[2] mt-10 md:hidden">
    <div
      class="relative mx-auto overflow-hidden rounded-2xl border border-white/8 bg-[radial-gradient(130%_120%_at_50%_0%,rgba(247,148,29,0.08),rgba(255,255,255,0)_55%),#121110] px-4 py-8"
    >
      <div class="mb-6 flex justify-center">
        <BrandImage variant="orange" class="h-14 w-auto drop-shadow-[0_0_20px_rgba(247,148,29,0.45)]" width={56} height={56} priority />
      </div>
      <div class="flex flex-wrap justify-center gap-2">
        {
          orbitNodes.map((node) => (
            <span class="inline-flex items-center gap-1.5 rounded-full border border-white/12 bg-[rgba(22,20,18,0.9)] px-3 py-1.5 font-mono text-[10px] tracking-wide text-[#d8d1c5]">
              <span class:list={["h-1.5 w-1.5 shrink-0 rounded-full", node.active ? "bg-brand" : "bg-text-dim"]} />
              {node.label.replace(/_/g, " ")}
            </span>
          ))
        }
      </div>
    </div>
  </Container>

  <!-- Desktop: órbita completa -->
  <Container class="relative z-[2] mt-12 hidden md:block md:mt-[70px]">
    <div
      class="relative mx-auto h-[min(52vw,480px)] min-h-[360px] max-w-[1080px] overflow-hidden rounded-3xl border border-white/8 bg-[radial-gradient(130%_120%_at_50%_0%,rgba(247,148,29,0.08),rgba(255,255,255,0)_55%),#121110]"
    >
      <div class="vz-grid-mask absolute inset-0 bg-size-[46px_46px]"></div>
      <div
        class="animate-vz-spin absolute top-1/2 left-1/2 h-[75%] w-[70%] max-h-[360px] max-w-[760px] rounded-full border border-dashed border-white/12"
      >
      </div>
      <div
        class="absolute top-1/2 left-1/2 h-[48%] w-[44%] max-h-[228px] max-w-[470px] -translate-x-1/2 -translate-y-1/2 rounded-full border border-white/8"
      >
      </div>
      <div
        class="absolute top-1/2 left-1/2 h-[54%] w-[54%] max-h-[260px] max-w-[260px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-[radial-gradient(circle,rgba(247,148,29,0.4),rgba(247,148,29,0)_65%)] blur-[14px]"
      >
      </div>

      <div class="animate-vz-float absolute top-1/2 left-1/2 z-[5]">
        <BrandImage variant="orange" class="h-14 w-auto lg:h-[78px] drop-shadow-[0_0_26px_rgba(247,148,29,0.55)]" width={78} height={78} priority />
      </div>

      {
        orbitNodes.map((node) => (
          <div
            class="absolute top-1/2 left-1/2 z-[6] [transform:translate(-50%,-50%)_translate(calc(var(--ox)*1px),calc(var(--oy)*1px))] max-lg:[--ox:calc(var(--x)*0.72)] max-lg:[--oy:calc(var(--y)*0.72)] lg:[--ox:var(--x)] lg:[--oy:var(--y)]"
            style={`--x:${node.x};--y:${node.y}`}
          >
            <div class="flex max-w-[min(90vw,220px)] items-center gap-2 rounded-full border border-white/12 bg-[rgba(22,20,18,0.9)] px-3 py-1.5 backdrop-blur-sm lg:max-w-none lg:px-4 lg:py-2">
              <span class:list={["h-1.5 w-1.5 shrink-0 rounded-full", node.active ? "bg-brand" : "bg-text-dim"]} />
              <span class="truncate font-mono text-[10px] tracking-wide text-[#d8d1c5] lg:text-[11.5px]">
                {node.label}
              </span>
            </div>
          </div>
        ))
      }
    </div>
  </Container>
</section>
