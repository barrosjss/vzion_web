---
import Container from "../ui/Container.astro";
import BrandImage from "../ui/BrandImage.astro";
import { site } from "../../data/site";
import { footerNav } from "../../data/navigation";
---

<footer class="relative z-[2] border-t border-white/7 bg-bg-footer pt-12 pb-[max(2.5rem,env(safe-area-inset-bottom))] md:pt-[72px]">
  <Container>
    <div class="grid gap-10 border-b border-white/7 pb-10 sm:grid-cols-2 lg:grid-cols-4 lg:pb-[52px]">
      <div class="sm:col-span-2 lg:col-span-1">
        <div class="mb-4 flex items-center gap-2.5">
          <BrandImage variant="orange" class="h-7 w-auto shrink-0" width={28} height={28} />
          <span class="pl-0.5 text-[17px] font-semibold tracking-[0.2em] sm:tracking-[0.32em]">{site.name}</span>
        </div>
        <p class="max-w-xs text-[15px] leading-relaxed text-text-dim">
          Tu brazo operativo as-a-service. Tú llevas la visión, nosotros ponemos la operación.
        </p>
      </div>

      <div>
        <h4 class="mb-4 font-mono text-[11px] font-medium uppercase tracking-widest text-text-footer">
          Navegación
        </h4>
        <ul class="flex flex-col gap-2.5">
          {
            footerNav.navigation.map((item) => (
              <li>
                <a href={item.href} class="text-[14.5px] text-text-muted transition-colors hover:text-brand">
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h4 class="mb-4 font-mono text-[11px] font-medium uppercase tracking-widest text-text-footer">
          Recursos
        </h4>
        <ul class="flex flex-col gap-2.5">
          {
            footerNav.resources.map((item) => (
              <li>
                <a href={item.href} class="text-[14.5px] text-text-muted transition-colors hover:text-brand">
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h4 class="mb-4 font-mono text-[11px] font-medium uppercase tracking-widest text-text-footer">
          Contacto
        </h4>
        <ul class="flex flex-col gap-2.5 text-[14.5px] text-text-muted">
          <li>
            <a href={`mailto:${site.contact.email}`} class="break-all transition-colors hover:text-brand">
              {site.contact.email}
            </a>
          </li>
          <li>{site.social.join(" · ")}</li>
        </ul>
      </div>
    </div>

    <div class="flex flex-col items-start justify-between gap-3 pt-7 sm:flex-row sm:items-center">
      <span class="font-mono text-xs text-text-footer">
        © {new Date().getFullYear()} {site.name} — Todos los derechos reservados.
      </span>
      <span class="font-mono text-xs text-text-footer">{site.motto}</span>
    </div>
  </Container>
</footer>
