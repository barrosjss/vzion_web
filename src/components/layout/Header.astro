---
import Container from "../ui/Container.astro";
import Button from "../ui/Button.astro";
import BrandImage from "../ui/BrandImage.astro";
import { site } from "../../data/site";
import { mainNav, isNavActive } from "../../data/navigation";

const pathname = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-white/7 bg-bg/72 pt-[env(safe-area-inset-top)] backdrop-blur-xl">
  <Container>
    <nav class="flex h-16 items-center justify-between gap-4 md:h-[72px] md:gap-8" aria-label="Principal">
      <a href="/" class="flex min-w-0 items-center gap-2 select-none">
        <BrandImage variant="orange" class="h-7 w-auto shrink-0" width={28} height={28} priority />
        <span class="truncate pl-0.5 text-[17px] font-semibold tracking-[0.2em] sm:tracking-[0.32em]">
          {site.name}
        </span>
      </a>

      <ul class="hidden items-center gap-0.5 md:flex">
        {
          mainNav.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={[
                  "rounded-lg px-3.5 py-2 font-mono text-[12.5px] font-medium tracking-wide transition-colors",
                  isNavActive(item.href, pathname) ? "text-brand" : "text-text-muted hover:text-text",
                ]}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>

      <div class="flex items-center gap-2">
        <Button href="/contacto" size="sm" class="hidden sm:inline-flex">
          Contáctanos
        </Button>

        <button
          type="button"
          id="mobile-menu-btn"
          class="inline-flex h-10 w-10 items-center justify-center rounded-lg border border-white/12 text-text transition-colors hover:border-white/25 hover:bg-white/5 md:hidden"
          aria-expanded="false"
          aria-controls="mobile-menu-panel"
          aria-label="Abrir menú de navegación"
        >
          <svg id="icon-menu" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round" />
          </svg>
          <svg id="icon-close" class="hidden h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M6 6l12 12M18 6L6 18" stroke-linecap="round" />
          </svg>
        </button>
      </div>
    </nav>
  </Container>

  <div
    id="mobile-menu-panel"
    class="pointer-events-none fixed inset-0 top-[calc(4rem+env(safe-area-inset-top))] z-40 opacity-0 transition-opacity duration-200 md:hidden"
    aria-hidden="true"
  >
    <div id="mobile-menu-backdrop" class="absolute inset-0 bg-black/60"></div>
    <div class="absolute top-0 right-0 left-0 border-b border-white/10 bg-bg/95 p-4 pb-6 shadow-2xl">
      <ul class="flex flex-col gap-1">
        {
          mainNav.map((item) => (
            <li>
              <a
                href={item.href}
                data-mobile-nav-link
                class:list={[
                  "block rounded-xl px-4 py-3.5 font-mono text-sm font-medium transition-colors",
                  isNavActive(item.href, pathname)
                    ? "bg-brand/10 text-brand"
                    : "text-text-muted hover:bg-white/5 hover:text-text",
                ]}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
      <div class="mt-4 border-t border-white/8 pt-4">
        <Button href="/contacto" size="md" class="w-full justify-center" data-mobile-nav-link>
          Contáctanos
        </Button>
      </div>
    </div>
  </div>
</header>

<script src="../../scripts/mobile-menu.ts"></script>
