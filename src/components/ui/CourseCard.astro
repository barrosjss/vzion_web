---
import type { Course } from "../../data/academy";
import { getCourseStats } from "../../data/academy";

type Props = {
  course: Course;
  href: string;
};

const { course, href } = Astro.props;
const { moduleCount, lessonCount } = getCourseStats(course);
---

<a
  href={href}
  class="group flex min-h-[200px] flex-col rounded-2xl border border-white/8 bg-white/[0.025] p-5 transition-all duration-200 hover:-translate-y-0.5 hover:border-brand/50 hover:bg-brand/[0.04] sm:min-h-[220px] sm:p-7"
>
  <div class="mb-auto flex items-start justify-between gap-2">
    <span class="font-mono text-[13px] text-text-faint">{course.n}</span>
    <span class="rounded-full bg-brand/10 px-2.5 py-1 font-mono text-[10px] font-medium uppercase tracking-wider text-brand">
      {course.tag}
    </span>
  </div>
  <h3 class="mt-5 mb-2 text-xl font-semibold tracking-tight sm:text-[23px]">{course.title}</h3>
  <p class="mb-4 text-sm leading-relaxed text-text-muted sm:text-[15px]">{course.desc}</p>
  <div class="flex flex-wrap items-center gap-3 font-mono text-[11px] text-text-dim">
    <span>{course.level}</span>
    <span aria-hidden="true">·</span>
    <span>{moduleCount} módulos</span>
    <span aria-hidden="true">·</span>
    <span>{lessonCount} clases</span>
    <span class="ml-auto text-lg text-text-faint transition-colors group-hover:text-brand">→</span>
  </div>
</a>
