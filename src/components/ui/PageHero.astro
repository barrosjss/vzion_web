---
import { cn } from "../../lib/utils";
import Container from "./Container.astro";

type Props = {
  class?: string;
  centered?: boolean;
  glow?: boolean;
};

const { class: className, centered = true, glow = true } = Astro.props;
---

<section class={cn("relative overflow-hidden py-12 pt-20 sm:py-14 sm:pt-24", className)}>
  {
    glow && (
      <div
        class="pointer-events-none absolute top-[-120px] left-1/2 h-[440px] w-full max-w-[760px] -translate-x-1/2 bg-[radial-gradient(closest-side,rgba(247,148,29,0.14),rgba(247,148,29,0)_75%)]"
        aria-hidden="true"
      />
    )
  }
  <Container>
    <div class={cn("relative", centered && "mx-auto max-w-4xl text-center")}>
      <slot />
    </div>
  </Container>
</section>
