---
import { cn } from "../../lib/utils";

type Props = {
  class?: string;
  size?: "sm" | "md" | "lg" | "xl";
};

const sizes = {
  sm: "max-w-3xl",
  md: "max-w-5xl",
  lg: "max-w-6xl",
  xl: "max-w-7xl",
};
---

<div class={cn("mx-auto w-full px-4 sm:px-6 lg:px-10", sizes[Astro.props.size ?? "xl"], Astro.props.class)}>
  <slot />
</div>
