---
import type { Service } from "../../data/services";

type Props = {
  service: Service;
  href: string;
  layout?: "grid" | "list";
};

const { service, href, layout = "grid" } = Astro.props;
const isList = layout === "list";
---

{
  isList ? (
    <a
      href={href}
      class="group flex flex-col gap-4 rounded-[18px] border border-white/8 bg-white/[0.025] p-5 transition-all duration-200 hover:border-brand/50 hover:bg-brand/[0.04] sm:flex-row sm:items-start sm:gap-6 sm:p-8"
    >
      <div class="shrink-0 font-mono text-[15px] text-brand sm:pt-1">{service.n}</div>
      <div class="min-w-0 flex-1">
        <div class="mb-2 flex items-start justify-between gap-3">
          <h3 class="min-w-0 text-lg font-semibold tracking-tight sm:text-[23px]">{service.title}</h3>
          <span class="shrink-0 text-lg text-text-faint transition-colors group-hover:text-text-muted">→</span>
        </div>
        <p class="mb-4 text-sm leading-relaxed text-text-muted sm:text-[15px]">{service.long}</p>
        <div class="flex flex-wrap gap-2">
          {service.items.map((item) => (
            <span class="rounded-full border border-white/7 bg-white/[0.04] px-3 py-1.5 font-mono text-[11px] text-text-muted sm:text-[11.5px]">
              {item}
            </span>
          ))}
        </div>
      </div>
    </a>
  ) : (
    <a
      href={href}
      class="group flex min-h-[168px] flex-col rounded-2xl border border-white/8 bg-white/[0.025] p-5 transition-all duration-200 hover:-translate-y-0.5 hover:border-brand/50 hover:bg-brand/[0.04] sm:min-h-[188px] sm:p-6"
    >
      <div class="mb-auto flex items-start justify-between gap-2">
        <span class="font-mono text-[13px] text-text-faint">{service.n}</span>
        <span class="rounded-full bg-brand/10 px-2 py-0.5 font-mono text-[9px] font-medium uppercase tracking-wider text-brand sm:px-2.5 sm:py-1 sm:text-[10.5px]">
          {service.tag}
        </span>
      </div>
      <h3 class="mt-4 mb-2 text-lg font-semibold tracking-tight sm:mt-5 sm:text-[21px]">{service.title}</h3>
      <p class="text-sm leading-normal text-text-muted sm:text-[14.5px]">{service.desc}</p>
    </a>
  )
}
