---
import { cn } from "../../lib/utils";

type Props = {
  name: string;
  role: string;
  initials: string;
  compact?: boolean;
};

const { name, role, initials, compact = false } = Astro.props;
---

<div
  class={cn(
    "rounded-2xl border border-white/8 bg-white/[0.025] text-center transition-all duration-200 hover:border-brand/40",
    compact ? "px-4 py-5" : "px-5 py-7 md:px-6",
  )}
>
  <div
    class={cn(
      "mx-auto mb-3.5 flex items-center justify-center rounded-full bg-gradient-to-br from-brand to-brand-muted font-mono font-bold text-bg",
      compact ? "mb-3.5 h-[52px] w-[52px] text-[17px]" : "mb-4 h-[62px] w-[62px] text-xl",
    )}
  >
    {initials}
  </div>
  <div class={cn("font-semibold tracking-tight", compact ? "text-sm" : "text-base")}>{name}</div>
  <div class="mt-1 font-mono text-xs leading-snug text-text-dim">{role}</div>
</div>
