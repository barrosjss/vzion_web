---
import BrandImage from "./BrandImage.astro";
import type { BlogPost } from "../../data/blog";

type Props = {
  post: BlogPost;
  showImage?: boolean;
};

const { post, showImage = true } = Astro.props;
---

<article class="group cursor-pointer">
  {
    showImage && (
      <div class="relative mb-4 flex aspect-[16/10] items-center justify-center overflow-hidden rounded-[14px] border border-white/8 bg-gradient-to-br from-surface-card to-surface">
        <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.04)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.04)_1px,transparent_1px)] bg-size-[28px_28px]" />
        <BrandImage variant="white" class="relative h-8 opacity-[0.16]" width={32} height={32} />
      </div>
    )
  }
  <div class="mb-2.5 flex items-center gap-2.5">
    <span class="font-mono text-[11px] font-medium uppercase tracking-wider text-brand">{post.cat}</span>
    <span class="font-mono text-[11.5px] text-text-faint">· {post.read}</span>
  </div>
  <h3 class="text-lg font-semibold leading-tight tracking-tight sm:text-xl">{post.title}</h3>
  <span class="mt-3.5 block font-mono text-xs text-text-faint">{post.date}</span>
</article>
